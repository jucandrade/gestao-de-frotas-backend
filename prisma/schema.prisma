generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Dados da Empresa
  companyCode String?
  companyName String
  tradeName   String?
  empCodFW    String?
  branchCode  String?

  // Dados Fiscais
  cnpj                   String  @unique
  stateRegistration      String?
  municipalRegistration  String?
  cnae                   String?
  taxRegime              String?

  // Endereço
  zipCode     String?
  streetType  String?
  streetName  String?
  number      String?
  complement  String?
  neighborhood String?
  cityCode    String?
  cityName    String?
  state       String?
  stateCode   String?
  country     String?
  fullAddress String?


  // Contato
  phone        String?
  contactName  String?
  whatsapp     String?
  email        String?

  @@map("companies")
}

model Vehicle {
  id           String    @id @default(uuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  plate        String    @unique
  chassis      String?
  prefix       String?
  manufacturer String?
  model        String?
  year         Int?
  color        String?
  fuel         String?
  renavam      String?
  status       String    @default("Ativo")

  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id])

  @@map("vehicles")
}

model UserProfile {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  name        String   @unique
  description String?

  // Permissões por módulo: { "companies": { "view": true, "create": false, ... }, ... }
  permissions Json     @default("{}")

  users       User[]

  @@map("user_profiles")
}

model User {
  id           String      @id @default(uuid())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  name         String
  email        String      @unique
  cpf          String?     @unique
  mobile       String?
  passwordHash String

  profileId    String
  profile      UserProfile @relation(fields: [profileId], references: [id])

  @@map("users")
}

model Customer {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastVisit DateTime?
  status    String   @default("Ativo")

  code                  String?
  name                  String
  tradeName             String?
  type                  String?
  cpf                   String?  @unique
  cnpj                  String?  @unique
  stateRegistration     String?
  ieIndicator           String?
  originCode            String?
  origin                String?
  mainContact           String?
  email                 String?
  phone                 String?
  commercialPhone       String?
  mobile                String?
  whatsapp              String?
  allowWhatsapp         Boolean  @default(false)
  allowEmail            Boolean  @default(false)
  allowSMS              Boolean  @default(false)
  allowPhone            Boolean  @default(false)
  zipCode               String?
  street                String?
  number                String?
  complement            String?
  neighborhood          String?
  city                  String?
  state                 String?
  cityCode              String?
  country               String?
  occupationCode        String?
  occupation            String?
  discountPercentage    Float?
  paymentMethod         String?
  paymentCondition      String?
  clientType            String?
  clientTypeDescription String?
  observations          String?

  vehicles              Vehicle[]
  contracts             Contract[]

  @@map("customers")
}

model Supplier {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Dados do Fornecedor
  code              String?
  name              String
  tradeName         String?
  supplierType      String?
  contactName       String?
  quotationContact  String?

  // Documentos
  personType        String?
  cnpj              String?  @unique
  cpf               String?  @unique
  stateRegistration String?
  ieIndicator       String?
  rg                String?

  // Endereço
  zipCode           String?
  streetType        String?
  street            String?
  number            String?
  complement        String?
  neighborhood      String?
  city              String?
  state             String?
  stateName         String?
  email             String?

  // Telefones
  phone             String?
  phone2            String?
  mobile            String?
  fax               String?

  // Financeiro
  paymentCondition  String?
  paymentDescription String?
  discountPercentage Float?
  site              String?
  observations      String?

  contacts          SupplierContact[]

  @@map("suppliers")
}

model SupplierContact {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sequence    Int?
  name        String
  positionCode String?
  positionDescription String?
  phone       String?
  email       String?
  active      Boolean @default(true)

  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@map("supplier_contacts")
}

model IntegrationSetting {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  key       String   @unique
  value     String
  enabled   Boolean  @default(false)

  @@map("integration_settings")
}

model Contract {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contractNumber    Int?
  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [id])
  customerName      String?
  startDate         DateTime?
  endDate           DateTime?

  contractType      String?
  contractYear      Int?
  extraCodeDRAC     String?
  deliveryLocation  String?

  // Valores financeiros
  totalValue        Float    @default(0)
  generalBalance    Float    @default(0)
  productPercentage Float    @default(0)
  productValue      Float    @default(0)
  servicePercentage Float    @default(0)
  serviceValue      Float    @default(0)

  // Reservas
  reserved          Float    @default(0)
  reserveBalance    Float    @default(0)
  reservedProduct   Float    @default(0)
  usedProduct       Float    @default(0)
  reservedService   Float    @default(0)
  usedService       Float    @default(0)

  items             ContractItem[]

  @@map("contracts")
}

model ContractItem {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ctoAcronym        String?
  ctoName           String?
  productPercentage Float    @default(0)
  servicePercentage Float    @default(0)
  value             Float    @default(0)
  reserved          Float    @default(0)
  productReserve    Float    @default(0)
  usedProduct       Float    @default(0)
  productBalance    Float    @default(0)
  serviceReserve    Float    @default(0)
  usedService       Float    @default(0)
  serviceBalance    Float    @default(0)
  balance           Float    @default(0)
  ctoCategory       String?

  contractId        String
  contract          Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("contract_items")
}
